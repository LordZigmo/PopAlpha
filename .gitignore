/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local agent/editor config
.claude/
.codex/

# External datasets
pokemon-tcg-data/
pokemon_card_detector-1/

# Local runtime state
scripts/import-state.json
scripts/justtcg-live-state.json

# Generated artifacts
scripts/output/
rf-detr-base.pth
ios/Sources/Features/Scanner/training_runs/
ios/Sources/Features/Scanner/ai_env/*
!ios/Sources/Features/Scanner/ai_env/download_data.py

# Supabase local temp
.supabase/

.vercel
.env*.local

# ── Xcode / iOS ──────────────────────────────────────────────────────────────
# User-specific Xcode state (window positions, breakpoints, scheme prefs).
# These change on every Xcode session and cause meaningless merge conflicts.
**/xcuserdata/
**/*.xcuserstate
# Xcode workspace settings (auto-generated, per-user)
*.xcworkspace/xcshareddata/IDEWorkspaceChecks.plist
# SPM build artifacts
.build/
ios/.swiftpm/
# Xcode DerivedData and build output
DerivedData/
ios/**/DerivedData/
ios/**/build/
# Archives and distribution artifacts
*.ipa
*.dSYM.zip
*.dSYM
*.xcarchive
# CocoaPods (if ever used)
ios/Pods/
# Fastlane artifacts
ios/fastlane/report.xml
ios/fastlane/Preview.html
ios/fastlane/screenshots/**/*.png

# ── Misc local artifacts ─────────────────────────────────────────────────────
*.png
!ios/PopAlphaApp/Assets.xcassets/**/*.png
