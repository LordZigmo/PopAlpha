<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.developer.applesignin</key>
	<array>
		<string>Default</string>
	</array>
	<!--
		APNs environment. "production" is required for both TestFlight
		and App Store builds (api.push.apple.com). Xcode debug builds
		installed directly to a device also work with "production" as
		long as the server's APNS_ENVIRONMENT env var matches. If you
		need to test against sandbox APNs (api.sandbox.push.apple.com)
		during local development, temporarily flip this to "development"
		and flip APNS_ENVIRONMENT on the server to match — see
		lib/push/apns.ts.
	-->
	<key>aps-environment</key>
	<string>production</string>
	<!--
		Universal Links. Apple's CDN fetches the AASA file from
		https://popalpha.ai/.well-known/apple-app-site-association
		(served by app/.well-known/apple-app-site-association/route.ts)
		on app install / first launch and caches the result. URL paths
		listed in that AASA route to the iOS app via
		.onContinueUserActivity(NSUserActivityTypeBrowsingWeb) — see
		DeepLinkRouter.swift.

		The "applinks:" prefix tells iOS this is a Universal Links domain
		(vs other associated-domain types like webcredentials). No
		subdomains are listed; if we ever want www.popalpha.ai or
		another subdomain to deep-link, add separate "applinks:..." rows.
	-->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:popalpha.ai</string>
	</array>
</dict>
</plist>
