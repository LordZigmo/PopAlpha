<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
		Export compliance. The app uses only standard HTTPS/TLS and
		platform-provided cryptography (URLSession, Sign in with Apple,
		Clerk iOS SDK over HTTPS). No custom or non-exempt encryption,
		so this qualifies for the mass-market exemption and no annual
		self-classification report is required. Flip to true only if
		the app starts shipping custom crypto — and then also answer
		the App Store Connect export compliance questions.
	-->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<!--
				The Clerk iOS SDK performs OAuth via ASWebAuthenticationSession,
				which uses its own ephemeral scheme matcher (callbackURLScheme)
				independent of this list. This entry is kept for debugging /
				openURL routing only. The scheme MUST match the SDK's default
				redirect URL format ({bundleIdentifier}://callback) because
				that's what gets sent to the OAuth provider and Clerk.
				Register the same value in the Clerk Dashboard → Native
				Applications → Allowed redirect URLs as:
					ai.popalpha.ios://callback
			-->
			<key>CFBundleURLName</key>
			<string>ai.popalpha.ios.clerk-callback</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>ai.popalpha.ios</string>
			</array>
		</dict>
	</array>
	<!--
		Custom launch screen: dark navy background asset with the PopAlpha
		logo centered. Replaces the auto-generated empty launch screen
		(INFOPLIST_KEY_UILaunchScreen_Generation has been turned off in the
		Xcode build settings so this dict is the source of truth).
	-->
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>LaunchBackground</string>
		<key>UIImageName</key>
		<string>LaunchLogo</string>
		<key>UIImageRespectsSafeAreaInsets</key>
		<false/>
	</dict>
	<key>UIBackgroundModes</key>
	<array>
		<!--
			Lets iOS deliver silent (content-available) pushes while the app
			is backgrounded so PushService can refresh the in-app
			notification badge and sync unread counts without the user
			opening the app. Required together with aps-environment.
		-->
		<string>remote-notification</string>
	</array>
	<!--
		NSPhotoLibraryAddUsageDescription is required because
		ScanDebugCapture (in DEBUG builds) saves each scanned card crop
		to Photos as a diagnostic artifact — operators review the
		saved captures alongside Logger.scan output to understand why
		a particular scan misfired. Without this key, iOS hard-crashes
		the app the first time PHPhotoLibrary write is attempted (it
		used to silently fall back to a permission-denied state on
		older iOS versions, but modern iOS treats missing usage strings
		for privacy-sensitive APIs as a hard violation).
		Release builds: ScanDebugCapture is #if DEBUG-gated and the
		Photos add path is dead code. The key being present doesn't
		trigger any user-facing prompt unless something on the release
		surface actually calls PHPhotoLibrary — which today nothing
		does. Worth re-removing this key if/when the DEBUG capture
		flow is replaced by something that writes to the app sandbox
		instead (preferred for App Review since "saves to Photos" is
		easier to misinterpret than a more bounded scope).
	-->
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Saves scan-capture diagnostics to Photos so you can review what the scanner actually saw on each scan attempt.</string>
</dict>
</plist>
