<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
		Export compliance. The app uses only standard HTTPS/TLS and
		platform-provided cryptography (URLSession, Sign in with Apple,
		Clerk iOS SDK over HTTPS). No custom or non-exempt encryption,
		so this qualifies for the mass-market exemption and no annual
		self-classification report is required. Flip to true only if
		the app starts shipping custom crypto — and then also answer
		the App Store Connect export compliance questions.
	-->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<!--
				The Clerk iOS SDK performs OAuth via ASWebAuthenticationSession,
				which uses its own ephemeral scheme matcher (callbackURLScheme)
				independent of this list. This entry is kept for debugging /
				openURL routing only. The scheme MUST match the SDK's default
				redirect URL format ({bundleIdentifier}://callback) because
				that's what gets sent to the OAuth provider and Clerk.
				Register the same value in the Clerk Dashboard → Native
				Applications → Allowed redirect URLs as:
					ai.popalpha.ios://callback
			-->
			<key>CFBundleURLName</key>
			<string>ai.popalpha.ios.clerk-callback</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>ai.popalpha.ios</string>
			</array>
		</dict>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<!--
			Lets iOS deliver silent (content-available) pushes while the app
			is backgrounded so PushService can refresh the in-app
			notification badge and sync unread counts without the user
			opening the app. Required together with aps-environment.
		-->
		<string>remote-notification</string>
	</array>
</dict>
</plist>
