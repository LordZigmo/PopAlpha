{
  "name": "popalpha",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run guard:no-cards-axis && npm run check:security:static && next build",
    "start": "next start",
    "lint": "eslint",
    "test:homepage": "node --experimental-strip-types --loader ./scripts/ts-root-loader.mjs tests/run-homepage-tests.mjs",
    "test:internal-admin": "node --experimental-strip-types --loader ./scripts/ts-root-loader.mjs tests/run-internal-admin-tests.mjs",
    "test:public-writes": "node --experimental-strip-types --loader ./scripts/ts-root-loader.mjs tests/run-public-write-tests.mjs",
    "test:search": "node tests/run-search-tests.mjs",
    "test:personalization": "node --experimental-strip-types --loader ./scripts/ts-root-loader.mjs tests/run-personalization-tests.mjs",
    "guard:no-cards-axis": "node scripts/check-no-cards-axis.mjs",
    "check:route-coverage": "node scripts/check-route-coverage.mjs",
    "check:internal-admin": "node scripts/check-internal-admin-pages.mjs",
    "check:internal-route-trust": "node scripts/check-internal-route-trust.mjs",
    "check:debug-route-trust": "node scripts/check-debug-route-trust.mjs",
    "check:public-writes": "node scripts/check-public-write-contracts.mjs",
    "check:script-trust": "node scripts/check-operational-script-trust.mjs",
    "check:privileged-entrypoints": "node scripts/check-privileged-entrypoints.mjs",
    "check:dbadmin": "node scripts/check-dbadmin-imports.mjs",
    "check:security:doctor": "node --env-file=.env.local scripts/check-linked-db-prereqs.mjs",
    "check:security:invariants": "node scripts/check-security-invariants.mjs",
    "check:security:static": "npm run check:route-coverage && npm run check:internal-admin && npm run check:internal-route-trust && npm run check:debug-route-trust && npm run check:public-writes && npm run check:script-trust && npm run check:privileged-entrypoints && npm run check:dbadmin",
    "check:security:schema": "node scripts/check-supabase-security.mjs",
    "check:security:schema:local": "node --env-file=.env.local scripts/check-supabase-security.mjs",
    "check:security": "npm run check:security:invariants",
    "ebay:deletion-setup": "node scripts/ebay-deletion-setup.mjs",
    "justtcg:backfill-live": "node scripts/backfill-justtcg-live.mjs",
    "sets:backfill-summaries": "node scripts/backfill-set-summaries.mjs",
    "import:scrydex-all": "node scripts/import-all-scrydex-canonical.mjs",
    "import:scrydex-missing-printings": "node scripts/import-scrydex-canonical-direct.mjs --only-missing",
    "report:set-efficiency": "node scripts/report-set-efficiency.mjs",
    "justtcg:repair-sweep": "node scripts/sweep-justtcg-finish-repair.mjs",
    "watch:unknown-finishes": "node scripts/watch-unknown-finishes.mjs",
    "ai:refresh-embeddings": "node scripts/refresh-card-embeddings.mjs",
    "env:pull-safe": "pwsh -File scripts/safe-env-pull.ps1",
    "verify:rls": "node --env-file=.env.local scripts/verify-phase1-rls.mjs",
    "verify:rls:linked": "node scripts/verify-phase1-rls.mjs"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.36",
    "@clerk/nextjs": "^6.39.0",
    "@neondatabase/serverless": "^1.0.2",
    "@supabase/supabase-js": "^2.97.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/postgres": "^0.10.0",
    "@vercel/speed-insights": "^1.3.1",
    "ai": "^6.0.108",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.34.5",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.576.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sharp": "^0.33.5",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.24",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "typescript": "^5",
    "undici": "^6.0.0"
  },
  "engines": {
    "node": "20.x"
  }
}
