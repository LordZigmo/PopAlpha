# Copy this file to .env.local for local development.
# Next.js will load .env.local automatically when you run `npm run dev`.

# PSA (server-only)
# Find this in your PSA developer/account portal.
PSA_ACCESS_TOKEN=
PSA_BASE_URL=https://api.psacard.com

# Primary Pricing DB (Supabase, server-only)
# Source of truth for ingestion, matching, timeseries, metrics, and APIs.
# In Supabase dashboard: Project Settings -> API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase browser credentials (safe to expose in browser bundle)
# In Supabase dashboard: Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI-only DB (Neon/Postgres, server-only)
# Do not use this for pricing ingestion or market APIs.
AI_NEON_DATABASE_URL=

# Pokemon TCG API (server-only)
# Official API (api.pokemontcg.io) — get key from https://dev.pokemontcg.io/
# Used by: canonical import, lib/pokemontcg client
POKEMONTCG_API_KEY=

# Pokemon TCG via RapidAPI (server-only) — different API, different key
# Used by: scripts/map-pokemon-tcg-api-sets.mjs only
POKEMON_TCG_API_KEY=
EUR_TO_USD_RATE=1.08

# Existing app env vars used by other routes/pages
CRON_SECRET=
ADMIN_SECRET=
NEXT_PUBLIC_SITE_URL=https://popalpha.app
