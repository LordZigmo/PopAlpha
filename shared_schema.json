{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Card",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "set",
    "price"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "set": {
      "type": [
        "string",
        "null"
      ]
    },
    "price": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    }
  }
}
